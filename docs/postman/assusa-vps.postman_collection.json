      "name": "7.2 listar boletos por CPF",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const hoje = new Date();",
              "const fim = hoje.toISOString().slice(0, 10);",
              "const inicio = new Date(hoje);",
              "inicio.setDate(inicio.getDate() - 30);",
              "pm.variables.set('DATA_INICIO', inicio.toISOString().slice(0, 10));",
              "pm.variables.set('DATA_FIM', fim);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" },
          { "key": "X-Internal-Api-Key", "value": "{{INTERNAL_API_KEY}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"numeroCliente\": 1964895,\n  \"numeroCpfCnpj\": \"{{CPF-TESTE-MAURI}}\",\n  \"dataInicio\": \"{{DATA_INICIO}}\",\n  \"dataFim\": \"{{DATA_FIM}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{PYTHON_URL}}/internal/boleto/listar",
          "host": ["{{PYTHON_URL}}"],
          "path": ["internal", "boleto", "listar"]
        },
        "description": "Datas calculadas automaticamente pelo pre-request script (hoje - 30 dias → hoje).\nLimite da API Sicoob: máx. 35 dias por chamada.\n\nO bot dispara 6 chamadas paralelas de 30 dias (SICOOB_NUM_JANELAS=6),\ncada uma atendida por este endpoint."
