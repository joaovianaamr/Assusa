# Facebook / WhatsApp Cloud API
ACCESS_TOKEN=your_whatsapp_access_token_here
APP_SECRET=your_facebook_app_secret_here
APP_ID=your_facebook_app_id_here

# Webhook URL verification (GET /webhook)
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
# VERIFY_TOKEN=legacy_same_value_ok  # legado — prefer WHATSAPP_VERIFY_TOKEN

# Server
PORT=8080

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Microsserviço Python (boletos Sicoob)
SICOOB_SERVICE_URL=http://127.0.0.1:8090
INTERNAL_API_KEY=your_internal_api_key_here
# true = sandbox (sem certificados reais); false = produção
SICOOB_SANDBOX=true
# Quantidade de janelas de 30 dias paralelas (1 janela = 1 mês de histórico)
# Default: 6 (cobre 6 meses, suficiente para inadimplência típica até o corte)
SICOOB_NUM_JANELAS=6

# Credenciais Sicoob — obrigatórias quando SICOOB_SANDBOX=false
SICOOB_CLIENT_ID=your_sicoob_client_id_here
# Número de cliente da Assusa no Sicoob (cedente)
SICOOB_NUMERO_CLIENTE=

# Certificados mTLS (arquivos extraídos do .pfx — obrigatórios em produção)
# Em Docker os caminhos são definidos no docker-compose.yml (/certs/...)
# Preencha abaixo apenas ao rodar o serviço Python fora do Docker
# SICOOB_CERT_PATH=/path/to/certificados/certificado.pem
# SICOOB_KEY_PATH=/path/to/certificados/private_key.pem

# URLs Sicoob — valores abaixo são os defaults do código; só defina para sobrescrever
# SICOOB_PROD_BASE_URL=https://api.sicoob.com.br
# SICOOB_SANDBOX_BASE_URL=https://sandbox.sicoob.com.br/sicoob/sandbox
# SICOOB_SANDBOX_TOKEN=
# SICOOB_SANDBOX_CLIENT_ID=

# PostgreSQL (persistência de interações)
DATABASE_URL=postgresql://assusa:change_me@localhost:5432/assusa
POSTGRES_PASSWORD=change_me